{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd frontend && npm ci",
  "buildCommand": "cd frontend && VITE_DEMO_MODE=static npm run build",
  "outputDirectory": "frontend/dist",
  "redirects": [
    {
      "source": "/",
      "destination": "/paper-demo",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://omnia-demo-api.onrender.com/api/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
